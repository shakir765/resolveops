{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug API",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "services.api.main:app",
        "--host",
        "127.0.0.1",
        "--port",
        "8000"
      ],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "jinja": true,
      "console": "integratedTerminal"
    },
    {
      "name": "Debug Graph Worker",
      "type": "debugpy",
      "request": "launch",
      "module": "services.graph_worker.main",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal"
    },
    {
      "name": "Debug RAG Service",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "services.rag_service.main:app",
        "--host",
        "127.0.0.1",
        "--port",
        "8002"
      ],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal"
    },
    {
      "name": "Debug Tool Runner",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "services.tool_runner.main:app",
        "--host",
        "127.0.0.1",
        "--port",
        "8003"
      ],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal"
    }
  ]
}
