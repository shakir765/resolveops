# ResolveOps environment configuration

# Database
DATABASE_URL=postgresql+psycopg://resolveops:resolveops@localhost:5432/resolveops

# Redis (locks, cache, sessions, LangGraph checkpoints)
REDIS_URL=redis://localhost:6379/0
# Optional dedicated Redis for checkpoints; defaults to REDIS_URL
REDIS_CHECKPOINT_URL=
# Checkpoint TTL in minutes (0 = no expiry)
REDIS_CHECKPOINT_TTL_MINUTES=0
REDIS_CHECKPOINT_REFRESH_ON_READ=true

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# LLM (optional — falls back to rule-based agents when unset)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Chroma / RAG
CHROMA_PERSIST_DIR=./data/chroma
RAG_SERVICE_URL=http://localhost:8002

# Tool Runner
TOOL_RUNNER_URL=http://localhost:8003

# Integrations (optional mock mode when unset)
SERVICENOW_INSTANCE=
SERVICENOW_USERNAME=
SERVICENOW_PASSWORD=
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=

# App
LOG_LEVEL=INFO
ENVIRONMENT=development
DEFAULT_TENANT_ID=default
PROMPT_VERSION=v1

# OpenTelemetry (traces + correlated logs)
OTEL_ENABLED=true
OTEL_LOGS_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_TRACES_SAMPLE_RATIO=1.0
